{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "uv run scripts/cues.py --hook",
            "statusMessage": "Loading session cues",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
