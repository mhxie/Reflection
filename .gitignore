# OS
.DS_Store

# Personal data (PRIVATE — never commit)
# Raw note snapshots
reflect-*/
# Reflection index with personal goals/summaries
index/
!index/.gitkeep
# Coaching session outputs
reflections/
!reflections/.gitkeep
# Personal reference material (examples, sensitive context)
personal/
!personal/.gitkeep
# Paper PDFs and local review artifacts
papers/
!papers/.gitkeep
# Handoff plans with personal note references
handoffs/
# Draft note content for Reflect compaction (temporary working files)
drafts/
# Local MCP server URL
.mcp.json
# Codex session state
.context/

# Build state
*.build-state.json
